<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ══════════════════════════════════════════════════
     VISTA KANBAN
     ══════════════════════════════════════════════════ -->
<record id="view_orden_corte_kanban" model="ir.ui.view">
    <field name="name">taller.orden.corte.kanban</field>
    <field name="model">taller.orden.corte</field>
    <field name="arch" type="xml">
        <kanban default_group_by="estado"
                quick_create="false"
                group_create="false"
                group_delete="false">

            <progressbar field="estado"
                         colors='{
                             "ingreso": "info",
                             "molderia": "warning",
                             "en_corte": "danger",
                             "control": "warning",
                             "entregado": "success"
                         }'/>

            <field name="name"/>
            <field name="molderia"/>
            <field name="tela"/>
            <field name="cantidad_total"/>
            <field name="fecha_entrega"/>
            <field name="cliente_id"/>
            <field name="estado"/>
            <field name="foto_referencia"/>
            <field name="color"/>

            <templates>
                <t t-name="kanban-box">
                    <div t-attf-class="oe_kanban_card oe_kanban_global_click">

                        <!-- Menú tres puntitos -->
                        <div class="o_dropdown_kanban dropdown">
                            <a class="dropdown-toggle o-no-caret btn"
                               data-bs-toggle="dropdown"
                               aria-expanded="false"
                               role="button">
                                <span class="fa fa-ellipsis-v"/>
                            </a>
                            <div class="dropdown-menu" role="menu">
                                <a role="menuitem"
                                   type="delete"
                                   class="dropdown-item">
                                    Eliminar
                                </a>
                            </div>
                        </div>

                        <!-- Cabecera: nombre + foto miniatura -->
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="o_kanban_record_title">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_subtitle text-muted">
                                    <field name="molderia"/>
                                </div>
                            </div>
                            <!-- Foto miniatura si existe -->
                            <div t-if="record.foto_referencia.raw_value"
                                 style="width:60px; height:60px; overflow:hidden; border-radius:4px; flex-shrink:0; margin-left:8px;">
                                <field name="foto_referencia"
                                       widget="image"
                                       options="{'size': [60, 60]}"
                                       style="width:60px; height:60px; object-fit:cover;"/>
                            </div>
                        </div>

                        <hr style="margin: 4px 0;"/>

                        <div>
                            <span class="text-muted">Tela: </span>
                            <field name="tela"/>
                        </div>
                        <div>
                            <span class="text-muted">Total: </span>
                            <strong><field name="cantidad_total"/></strong>
                        </div>
                        <div>
                            <span class="text-muted">Entrega: </span>
                            <field name="fecha_entrega"/>
                        </div>

                        <div class="oe_kanban_bottom_right mt-2">
                            <field name="cliente_id"
                                   widget="many2one_avatar"/>
                        </div>

                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>


<!-- ══════════════════════════════════════════════════
     VISTA FORMULARIO
     ══════════════════════════════════════════════════ -->
<record id="view_orden_corte_form" model="ir.ui.view">
    <field name="name">taller.orden.corte.form</field>
    <field name="model">taller.orden.corte</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <field name="estado"
                       widget="statusbar"
                       statusbar_visible="ingreso,molderia,en_corte,control,entregado"
                       options="{'clickable': 1}"/>
            </header>
            <sheet>
                <group>
                    <group string="Datos de la Orden">
                        <field name="name" placeholder="Ej: OC-2045"/>
                        <field name="molderia"/>
                        <field name="tela"/>
                        <field name="cliente_id"/>
                        <field name="fecha_ingreso"/>
                        <field name="fecha_entrega"/>
                    </group>
                    <group string="Foto de Referencia del Cliente">
                        <field name="foto_referencia"
                               widget="image"
                               options="{'size': [400, 400]}"
                               nolabel="1"/>
                    </group>
                </group>

                <notebook>

                    <page string="Talles y Cantidades">
                        <field name="lineas_talle_ids">
                            <tree editable="bottom"
                                  decoration-muted="cantidad == 0"
                                  limit="30">
                                <field name="talle" string="Talle"/>
                                <field name="color_tela" string="Color"/>
                                <field name="cantidad" string="Cantidad"/>
                            </tree>
                        </field>
                        <group>
                            <field name="cantidad_total"
                                   string="TOTAL DE PIEZAS"
                                   readonly="1"/>
                        </group>
                    </page>

                    <page string="Tizadas">
                        <field name="lineas_tizada_ids">
                            <tree editable="bottom">
                                <field name="tipo_tela"/>
                                <field name="descripcion"/>
                                <field name="ancho_tizada"/>
                                <field name="largo_tizada"/>
                                <field name="consumo" readonly="1"/>
                            </tree>
                        </field>
                    </page>

                    <page string="Notas">
                        <field name="notas"
                               placeholder="Instrucciones especiales, observaciones..."
                               nolabel="1"/>
                    </page>

                </notebook>
            </sheet>
            <chatter/>
        </form>
    </field>
</record>


<!-- ══════════════════════════════════════════════════
     VISTA LISTA
     ══════════════════════════════════════════════════ -->
<record id="view_orden_corte_list" model="ir.ui.view">
    <field name="name">taller.orden.corte.list</field>
    <field name="model">taller.orden.corte</field>
    <field name="arch" type="xml">
        <tree decoration-success="estado == 'entregado'"
              decoration-warning="estado == 'en_corte'"
              decoration-info="estado == 'molderia'">
            <field name="name"/>
            <field name="molderia"/>
            <field name="tela"/>
            <field name="cantidad_total"/>
            <field name="cliente_id"/>
            <field name="fecha_ingreso"/>
            <field name="fecha_entrega"/>
            <field name="estado"/>
        </tree>
    </field>
</record>


<!-- ══════════════════════════════════════════════════
     ACCIÓN y MENÚ
     ══════════════════════════════════════════════════ -->
<record id="action_orden_corte" model="ir.actions.act_window">
    <field name="name">Órdenes de Corte</field>
    <field name="res_model">taller.orden.corte</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="context">{'default_estado': 'ingreso'}</field>
</record>

<menuitem id="menu_taller_corte_root"
          name="Taller de Corte"
          sequence="10"
          web_icon="taller_corte,static/description/icon.png"/>

<menuitem id="menu_ordenes_corte"
          name="Órdenes de Corte"
          parent="menu_taller_corte_root"
          action="action_orden_corte"
          sequence="1"/>

</odoo>