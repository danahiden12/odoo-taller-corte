<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Formato de página personalizado -->
<record id="paperformat_taller_corte" model="report.paperformat">
    <field name="name">Taller de Corte A4</field>
    <field name="default" eval="False"/>
    <field name="format">A4</field>
    <field name="orientation">Portrait</field>
    <field name="margin_top">5</field>
    <field name="margin_bottom">5</field>
    <field name="margin_left">5</field>
    <field name="margin_right">5</field>
    <field name="header_line" eval="False"/>
    <field name="header_spacing">0</field>
    <field name="dpi">90</field>
</record>

<record id="action_reporte_orden_corte" model="ir.actions.report">
    <field name="name">Hoja de Corte</field>
    <field name="model">taller.orden.corte</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">taller_corte.reporte_orden_corte</field>
    <field name="report_file">taller_corte.reporte_orden_corte</field>
    <field name="binding_model_id" ref="model_taller_orden_corte"/>
    <field name="binding_type">report</field>
    <field name="paperformat_id" ref="taller_corte.paperformat_taller_corte"/>
</record>

<template id="reporte_orden_corte">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="doc">

<!-- Sin external_layout para evitar header/footer duplicado -->
<div class="page" style="font-family: Arial, sans-serif; padding: 10px; font-size: 11px;">

    <!-- ── ENCABEZADO ── -->
    <div style="border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom:10px;">
        <table width="100%">
            <tr>
                <!-- Lado izquierdo: N° orden y estado -->
                <td width="50%">
                    <h2 style="margin:0; font-size:20px; color:#333;">
                        <t t-esc="doc.name"/>
                    </h2>
                    <p style="margin:4px 0 0 0; color:#666; font-size:12px;">
                        Estado: <t t-esc="dict(doc._fields['estado'].selection).get(doc.estado, doc.estado)"/>
                    </p>
                </td>
                <!-- Lado derecho: nombre del taller -->
                <td width="50%" style="text-align:right;">
                    <h1 style="margin:0; font-size:18px; color:#333;">
                        WR - Taller de Corte
                    </h1>
                    <p style="margin:4px 0 0 0; color:#666; font-size:11px;">
                        Hoja de Orden de Corte
                    </p>
                </td>
            </tr>
        </table>
    </div>

    <!-- ── DATOS PRINCIPALES ── -->
    <table width="100%" style="margin-bottom:10px;">
        <tr>
            <td width="50%" style="vertical-align:top;">
                <table style="width:100%; font-size:12px;">
                    <tr>
                        <td style="color:#666; width:40%; padding:4px 0;">Molderia:</td>
                        <td style="font-weight:bold; padding:4px 0;">
                            <t t-esc="doc.molderia or '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#666; padding:4px 0;">Tela / Material:</td>
                        <td style="font-weight:bold; padding:4px 0;">
                            <t t-esc="doc.tela or '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#666; padding:4px 0;">Cliente:</td>
                        <td style="font-weight:bold; padding:4px 0;">
                            <t t-esc="doc.cliente_id.name or '-'"/>
                        </td>
                    </tr>
                </table>
            </td>
            <td width="50%" style="vertical-align:top;">
                <table style="width:100%; font-size:12px;">
                    <tr>
                        <td style="color:#666; width:40%; padding:4px 0;">Fecha Ingreso:</td>
                        <td style="font-weight:bold; padding:4px 0;">
                            <t t-esc="doc.fecha_ingreso or '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#666; padding:4px 0;">Fecha Entrega:</td>
                        <td style="font-weight:bold; padding:4px 0;">
                            <t t-esc="doc.fecha_entrega or '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#666; padding:4px 0;">Total Piezas:</td>
                        <td style="font-weight:bold; font-size:14px; padding:4px 0;">
                            <t t-esc="doc.cantidad_total"/>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <!-- ── TABLA DE TALLES ── -->
    <div style="margin-bottom:10px;">
        <h3 style="font-size:13px; border-bottom:1px solid #ccc; padding-bottom:4px; margin-bottom:8px;">
            TALLES Y CANTIDADES
        </h3>
        <table width="100%" style="border-collapse:collapse; font-size:12px;">
            <thead>
                <tr style="background:#f0f0f0;">
                    <th style="border:1px solid #ccc; padding:6px; text-align:left;">Talle</th>
                    <th style="border:1px solid #ccc; padding:6px; text-align:left;">Color</th>
                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">Cantidad</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="doc.lineas_talle_ids" t-as="linea">
                    <tr>
                        <td style="border:1px solid #ccc; padding:6px;">
                            <t t-esc="dict(linea._fields['talle'].selection).get(linea.talle, linea.talle)"/>
                        </td>
                        <td style="border:1px solid #ccc; padding:6px;">
                            <t t-esc="linea.color_tela.name or '-'"/>
                        </td>
                        <td style="border:1px solid #ccc; padding:6px; text-align:center;">
                            <t t-esc="linea.cantidad"/>
                        </td>
                    </tr>
                </t>
            </tbody>
            <tfoot>
                <tr style="background:#f0f0f0; font-weight:bold;">
                    <td colspan="2" style="border:1px solid #ccc; padding:6px; text-align:right;">TOTAL:</td>
                    <td style="border:1px solid #ccc; padding:6px; text-align:center;">
                        <t t-esc="doc.cantidad_total"/>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>

    <!-- ── TABLA DE TIZADAS ── -->
    <div t-if="doc.lineas_tizada_ids" style="margin-bottom:10px;">
        <h3 style="font-size:13px; border-bottom:1px solid #ccc; padding-bottom:4px; margin-bottom:8px;">
            TIZADAS
        </h3>
        <table width="100%" style="border-collapse:collapse; font-size:12px;">
            <thead>
                <tr style="background:#f0f0f0;">
                    <th style="border:1px solid #ccc; padding:6px; text-align:left;">Tipo de Tela</th>
                    <th style="border:1px solid #ccc; padding:6px; text-align:left;">Descripcion</th>
                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">Ancho (mts)</th>
                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">Largo (mts)</th>
                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">Consumo (mts)</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="doc.lineas_tizada_ids" t-as="linea">
                    <tr>
                        <td style="border:1px solid #ccc; padding:6px;">
                            <t t-esc="dict(linea._fields['tipo_tela'].selection).get(linea.tipo_tela, linea.tipo_tela)"/>
                        </td>
                        <td style="border:1px solid #ccc; padding:6px;">
                            <t t-esc="linea.descripcion or '-'"/>
                        </td>
                        <td style="border:1px solid #ccc; padding:6px; text-align:center;">
                            <t t-esc="linea.ancho_tizada"/>
                        </td>
                        <td style="border:1px solid #ccc; padding:6px; text-align:center;">
                            <t t-esc="linea.largo_tizada"/>
                        </td>
                        <td style="border:1px solid #ccc; padding:6px; text-align:center;">
                            <t t-esc="linea.consumo"/>
                        </td>
                    </tr>
                </t>
            </tbody>
        </table>
    </div>

    <!-- ── FOTO DE REFERENCIA ── -->
    <div t-if="doc.foto_referencia" style="margin-bottom:10px;">
        <h3 style="font-size:13px; border-bottom:1px solid #ccc; padding-bottom:4px; margin-bottom:8px;">
            FOTO DE REFERENCIA DEL CLIENTE
        </h3>
        <img t-att-src="image_data_uri(doc.foto_referencia)"
            style="max-width:500px; max-height:400px;"/>
    </div>

    <!-- ── NOTAS ── -->
    <div t-if="doc.notas" style="margin-bottom:10px;">
        <h3 style="font-size:13px; border-bottom:1px solid #ccc; padding-bottom:4px; margin-bottom:8px;">
            NOTAS / INSTRUCCIONES ESPECIALES
        </h3>
        <p style="font-size:12px; border:1px solid #ccc; padding:10px; border-radius:4px;">
            <t t-esc="doc.notas"/>
        </p>
    </div>

    <!-- ── PIE ── -->
    <div style="border-top:1px solid #ccc; padding-top:8px; margin-top:20px; font-size:10px; color:#999; text-align:center;">
        Documento generado por el sistema de gestion del Taller de Corte
    </div>

</div>

</t>
</t>
</template>

</odoo>
